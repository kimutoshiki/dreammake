# ==============================================================================
# しらべてつくろう!AIラボ — 環境変数テンプレート
# ==============================================================================
# 使い方: このファイルを `.env.local` にコピーし、各値を埋める。
#   cp .env.example .env.local
#
# ⚠️ .env.local は絶対にコミットしない(.gitignore で除外済み)。
# ⚠️ API キーは必ずサーバーサイドでのみ使用すること。クライアントに露出禁止。
# ==============================================================================


# ------------------------------------------------------------------------------
# Anthropic Claude API(必須)
# ------------------------------------------------------------------------------
# 取得: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# デフォルトの対話・コード生成・インフォグラフィック生成モデル
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6

# モデレーション・軽量処理用モデル(高速・低コスト)
ANTHROPIC_MODEL_MODERATION=claude-haiku-4-5-20251001

# API 呼び出しの最大リトライ回数(指数バックオフ)
ANTHROPIC_MAX_RETRIES=3

# API 呼び出しのタイムアウト(ミリ秒)
ANTHROPIC_TIMEOUT_MS=30000


# ------------------------------------------------------------------------------
# 画像生成プロバイダ(Phase 2 以降で使用)
# ------------------------------------------------------------------------------
# gemini | openai | none
IMAGE_PROVIDER=gemini

# Google Gemini(Nano Banana / Imagen)
# 取得: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_IMAGE_MODEL=imagen-3

# OpenAI 画像 API(Gemini フォールバック / 代替用)
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1


# ------------------------------------------------------------------------------
# データベース(SQLite ローカル開発 / Postgres 本番)
# ------------------------------------------------------------------------------
# ローカル開発: SQLite ファイルパス
DATABASE_URL=file:./dev.db

# 本番例: postgresql://user:pass@host:5432/dbname?schema=public


# ------------------------------------------------------------------------------
# ストレージ(画像・PDF・作品アーカイブ)
# ------------------------------------------------------------------------------
# local | minio
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./storage

# MinIO(S3 互換、オンプレ本番向け)
MINIO_ENDPOINT=
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=shirabete-tsukurou


# ------------------------------------------------------------------------------
# 認証(Auth.js / NextAuth v5)
# ------------------------------------------------------------------------------
# セッション暗号化用シークレット(本番は必ず `openssl rand -base64 32` で生成)
AUTH_SECRET=

# マジックリンク送信用 SMTP(教員・保護者用)
# ローカル開発では MailHog (http://localhost:8025) を推奨
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@shirabete-tsukurou.local

# 児童の絵柄パスワード設定
# 選択肢の絵柄プール数(大きいほど安全だが低学年には難しい)
KIDS_EMOJI_POOL_SIZE=12
# 1つの絵柄パスワードが使う絵柄の数(3〜5 推奨)
KIDS_EMOJI_PASSWORD_LENGTH=3
# 連続失敗で一時ロックまでの回数
KIDS_AUTH_MAX_ATTEMPTS=5
# ロック時間(分)
KIDS_AUTH_LOCKOUT_MINUTES=10


# ------------------------------------------------------------------------------
# 探究単元・研究機能(Phase 2 以降)
# ------------------------------------------------------------------------------
# 研究機能(エピソード抽出・共起分析・Wilcoxon 比較)の全面有効化
# オフにすると、単元は使えるが研究用の派生データは生成されない
RESEARCH_FEATURES_ENABLED=true

# エピソード抽出・対話ログ PII マスクのペッパー(匿名 ID 生成に使用)
# 本番は十分長いランダム値を設定。漏洩時は匿名性が損なわれる
RESEARCH_ANONYMOUS_ID_PEPPER=

# 立ち止まりの言葉検出の LLM 併用(false の場合はルールベースのみ)
STANDSTILL_USE_LLM=true

# kuromoji 辞書のパス(共起分析・ふりがな両方で使用)
KUROMOJI_DICT_PATH=./public/dict

# 事前事後アンケートの自動生成を AI で許可するか
SURVEY_AI_GEN_ENABLED=true

# 研究用データの保管期限(日)
# ConsentRecord(research-participation) を撤回すると、この期限内でも物理削除される
RESEARCH_DATA_RETENTION_DAYS=365

# 単元の最大時数(UI 制限、plannedHours のバリデーション)
UNIT_MAX_HOURS=20

# 対話ログの児童本人返却を許可するか(Phase 2 の既定で ON)
CHAT_LOG_RETURN_ENABLED=true


# ------------------------------------------------------------------------------
# 表現系(Phase 3:動画・音楽・クイズ)
# ------------------------------------------------------------------------------
# 動画合成の最大秒数(児童作品)
VIDEO_MAX_DURATION_SEC=60

# BGM 生成の最大秒数
MUSIC_MAX_DURATION_SEC=60

# 動画の最大スライド数
VIDEO_MAX_SLIDES=8


# ------------------------------------------------------------------------------
# 安全設計(依存防止・コスト上限)
# ------------------------------------------------------------------------------
# 1ユーザーあたりの1日の LLM 呼び出し上限
SAFETY_DAILY_LLM_CALL_LIMIT_PER_USER=100

# 連続使用で休憩を促すまでの分数
SAFETY_CONTINUOUS_USE_WARN_MINUTES=20

# 画像アップロード時の自動顔ぼかしをデフォルト ON にするか
SAFETY_FACE_BLUR_DEFAULT=true

# モデレーションでハードブロック時の通知先(教員メール)
SAFETY_INCIDENT_NOTIFY_EMAIL=


# ------------------------------------------------------------------------------
# アプリ設定
# ------------------------------------------------------------------------------
# 公開 URL(マジックリンク生成などで使用)
NEXTAUTH_URL=http://localhost:3000

# デフォルトの学年プロファイル(lower | middle | upper)
DEFAULT_GRADE_PROFILE=middle

# 監査ログの保存期間(日)
AUDIT_LOG_RETENTION_DAYS=365

# Node 環境
NODE_ENV=development


# ------------------------------------------------------------------------------
# 開発支援(任意)
# ------------------------------------------------------------------------------
# Sentry(エラー監視)
SENTRY_DSN=

# PostHog(プロダクト分析 — 児童の個人情報を送らない設定必須)
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com
