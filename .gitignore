# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
.next/
out/
build/
dist/

# Local env
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Prisma SQLite
prisma/*.db
prisma/*.db-journal
prisma/migrations/**/*.sql.bak

# Dev storage (ローカル FS 実装のアップロード先)
/storage/

# Runtime uploads(児童が カメラ/マイク/お絵かきで 作った作品)
# 中身は Git 管理せず、.gitkeep だけ残す
/public/uploads/*
!/public/uploads/.gitkeep

# Testing
coverage/
.nyc_output/
playwright-report/
test-results/

# Misc
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Vercel(使わない予定だが念のため)
.vercel
