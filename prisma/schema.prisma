// Prisma schema for しらべてつくろう!AIラボ(児童向け縮小版)
//
// 教員の管理 UI・研究機能を 外し、児童が 授業中に iPad で 主体的に
// 使う 要素だけを 残した 最小構成。
// SQLite ファイル 1 つで 動く。学校の タブレット・先生の PC に
// ローカル保管で 使える。

generator client {
  provider        = "prisma-client-js"
  // Turso(libSQL) を Vercel デプロイで 使うため driverAdapters を 有効化。
  previewFeatures = ["driverAdapters"]
}

datasource db {
  // ローカル開発:SQLite ファイル(file:./dev.db)
  // 本番 (Vercel):同じ schema を libSQL アダプタ経由で Turso(SQLite クラウド)に
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------
// 組織(ゆるく グループ化するためだけに 残す)
// -----------------------------------------------------------
model School {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  classes   Class[]
  users     User[]
}

model Class {
  id           String            @id @default(cuid())
  schoolId     String
  school       School            @relation(fields: [schoolId], references: [id])
  name         String
  gradeYear    Int
  defaultGrade String
  createdAt    DateTime          @default(now())
  memberships  ClassMembership[]
  bots         Bot[]

  @@index([schoolId])
}

model ClassMembership {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String   // 'student'(現状は 児童のみ)
  createdAt DateTime @default(now())

  @@unique([classId, userId])
  @@index([userId])
}

// -----------------------------------------------------------
// ユーザー(児童のみ)
// -----------------------------------------------------------
model User {
  id              String        @id @default(cuid())
  role            String        @default("student")
  schoolId        String?
  school          School?       @relation(fields: [schoolId], references: [id])
  handle          String?       @unique
  nickname        String?
  avatarSeed      String?
  gradeProfileId  String?       @unique
  gradeProfile    GradeProfile? @relation(fields: [gradeProfileId], references: [id])

  memberships     ClassMembership[]
  bots            Bot[]             @relation("botOwner")
  conversations   Conversation[]
  artworks        Artwork[]
  fieldNotes      FieldNote[]       @relation("fieldNoteUser")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastActiveAt    DateTime?

  @@index([role, schoolId])
}

model GradeProfile {
  id            String  @id @default(cuid())
  band          String  // 'lower' | 'middle' | 'upper'
  gradeYear     Int?
  furiganaMode  String
  voiceFirst    Boolean @default(false)
  maxQaChars    Int
  overrides     String  @default("{}")
  user          User?
}

// -----------------------------------------------------------
// ボットと ナレッジ
// -----------------------------------------------------------
model Bot {
  id             String  @id @default(cuid())
  ownerId        String
  owner          User    @relation("botOwner", fields: [ownerId], references: [id])
  classId        String?
  class          Class?  @relation(fields: [classId], references: [id])
  name           String
  avatarSeed     String
  persona        String
  strengths      String  @default("")
  weaknesses     String  @default("")
  topic          String
  isPublic       Boolean @default(false)

  knowledgeCards KnowledgeCard[]
  sources        Source[]
  conversations  Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model KnowledgeCard {
  id        String   @id @default(cuid())
  botId     String
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  kind      String   @default("qa")
  question  String?
  answer    String
  sourceIds String   @default("[]")
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([botId, order])
}

model Source {
  id          String   @id @default(cuid())
  botId       String
  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  kind        String
  title       String
  authorOrWho String?
  url         String?
  createdAt   DateTime @default(now())

  @@index([botId])
}

// -----------------------------------------------------------
// 対話
// -----------------------------------------------------------
model Conversation {
  id            String    @id @default(cuid())
  botId         String
  bot           Bot       @relation(fields: [botId], references: [id])
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  startedAt     DateTime  @default(now())
  lastMessageAt DateTime  @default(now())
  closed        Boolean   @default(false)
  messages      Message[]
  artworks      Artwork[]

  @@index([userId, lastMessageAt])
  @@index([botId, lastMessageAt])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  rawContent     String?
  citedSourceIds String        @default("[]")
  moderation     ModerationLog?
  tokensIn       Int?
  tokensOut      Int?
  latencyMs      Int?
  createdAt      DateTime      @default(now())

  @@index([conversationId, createdAt])
}

// -----------------------------------------------------------
// 作品(写真・動画・録音・絵・AI絵・おんがく・クイズ・ミニアプリ)
// -----------------------------------------------------------
model Artwork {
  id                   String        @id @default(cuid())
  ownerId              String
  owner                User          @relation(fields: [ownerId], references: [id])
  kind                 String
  title                String

  imageUrl             String?
  imageProvider        String?
  imageModel           String?
  finalPrompt          String?
  safetyFilteredPrompt String?

  videoUrl             String?
  videoScript          String?       // 動画マーカーの JSON も ここに 保存
  videoDurationSec     Int?

  audioUrl             String?
  audioTranscript      String?
  audioDurationSec     Int?

  musicUrl             String?
  musicScore           String?
  musicMood            String?

  quizSpec             String?
  quizKind             String?

  // 🎮 ゲームをつくる(もぐらたたき): JSON で 設定を 保存
  gameSpec             String?

  // 🧩 ノーコードプログラミング(命令ブロック): JSON で コマンド列を 保存
  programSpec          String?

  createdInConversationId String?
  createdInConversation   Conversation? @relation(fields: [createdInConversationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, kind])
}

// -----------------------------------------------------------
// 記録ノート(写真/録音/絵/テキストを 1 枚のカードに 束ねる)
// -----------------------------------------------------------
model FieldNote {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("fieldNoteUser", fields: [userId], references: [id])
  title        String
  notes        String   @default("")
  locationNote String?
  artworkIds   String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, createdAt])
}

// -----------------------------------------------------------
// 安全(モデレーション・インシデント・監査)
// -----------------------------------------------------------
model ModerationLog {
  id         String   @id @default(cuid())
  stage      String
  messageId  String?  @unique
  message    Message? @relation(fields: [messageId], references: [id])
  decision   String
  categories String   @default("[]")
  model      String
  reason     String?
  userId     String
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([decision, createdAt])
}

model IncidentReport {
  id        String   @id @default(cuid())
  severity  String
  kind      String
  actorId   String?
  summary   String
  payload   String?
  createdAt DateTime @default(now())

  @@index([severity, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String?
  model     String?
  tokensIn  Int?
  tokensOut Int?
  meta      String?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
}
